<Window x:Class="FieldManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FieldManagement"
        xmlns:views="clr-namespace:FieldManagement.Views"
        mc:Ignorable="d"
        Title="Field Management"
        Height="720"
        Width="1280"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#0F172A">
    
    <Window.Resources>
       <!-- 사이드바 토글 버튼 스타일 -->
       <Style x:Key="SidebarRadioStyle" TargetType="RadioButton">
           <Setter Property="Width" Value="72"/>
           <Setter Property="Height" Value="72"/>
           <Setter Property="Margin" Value="8,6"/>
           <Setter Property="Foreground" Value="#E5E7EB"/>
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderBrush" Value="Transparent"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="RadioButton">
                       <Grid>
                           <Border x:Name="Indicator"
                                   Width="4"
                                   Margin="0,8,0,8"
                                   HorizontalAlignment="Left"
                                   Background="Transparent"
                                   CornerRadius="2"/>

                           <Border x:Name="ButtonBody"
                                   Margin="8,0,0,0"
                                   Background="Transparent"
                                   CornerRadius="14">
                               <ContentPresenter HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                           </Border>
                       </Grid>

                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="ButtonBody" Property="Background" Value="#2A2540"/>
                           </Trigger>

                           <Trigger Property="IsChecked" Value="True">
                               <Setter TargetName="Indicator" Property="Background" Value="#3BA3FF"/>
                               <Setter TargetName="ButtonBody" Property="Background" Value="#241F38"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
       
        <!-- 하단 작은 버튼 -->
        <Style x:Key="SidebarBottomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBody"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="#2A2540"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="#342E50"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 오른쪽 로그 리스트 스타일 -->
        <Style x:Key="LogListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="LogListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="#111827"/>
            <Setter Property="Foreground" Value="#E5E7EB"/>
            <Setter Property="BorderBrush" Value="#1F2937"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1F2937"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#243047"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3BA3FF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="88"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 사이드바 -->
        <Border Grid.Column="0"
                Background="#171427">
            <DockPanel LastChildFill="True">

                <!-- 하단 -->
                <StackPanel DockPanel.Dock="Bottom"
                            Margin="0,0,0,10">
                    <Button Style="{StaticResource SidebarBottomButtonStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="◐"
                                       FontSize="22"
                                       Foreground="#E5E7EB"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Theme"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 상단 메뉴 -->
                <StackPanel Margin="0,10,0,0">
                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                  Tag="Home"
                                  Checked="MenuRadio_Checked">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="#60A5FA"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Home"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 Checked="MenuRadio_Checked"
                                 Tag="Input">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="#E5E7EB"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Input"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 Checked="MenuRadio_Checked">
                                 <!-- Tag="Data" -->
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="#E5E7EB"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Data"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 Checked="MenuRadio_Checked">
                                 <!-- Tag="Logs" -->
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="#E5E7EB"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Logs"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 Checked="MenuRadio_Checked">
                                 <!--Tag="Settings"-->
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="#E5E7EB"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Setting"
                                       FontSize="11"
                                       Foreground="#E5E7EB"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl x:Name="MainContent"
                        Grid.Column="1"
                        Margin="14"/>
    </Grid>
</Window>
