<UserControl x:Class="FieldManagement.View.DataView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">

    <UserControl.Resources>
        <ControlTemplate x:Key="RoundedComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0"
                                      Margin="12,0,8,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      RecognizesAccessKey="True" />
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0"
                          Stroke="{DynamicResource ComboBoxArrowBrush}"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxHoverBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxHoverBorderBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxOpenBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxOpenBorderBrush}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxOpenArrowBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxDisabledBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxDisabledBorderBrush}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxDisabledArrowBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="RoundedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemForegroundBrush}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemSelectedBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource RoundedComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Template="{StaticResource RoundedComboBoxToggleButton}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource ComboBoxBackgroundBrush}"
                                        BorderBrush="{DynamicResource ComboBoxPopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer Margin="0,2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource ComboBoxFocusBorderBrush}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="40" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundBrush}" />
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,12"
                Background="{DynamicResource ViewPanelBackgroundBrush}"
                BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="작업지시번호" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <TextBox Grid.Column="1" Style="{StaticResource RoundedTextBox}" />

                <TextBlock Grid.Column="3" Text="설비명" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <TextBox Grid.Column="4" Style="{StaticResource RoundedTextBox}" />

                <TextBlock Grid.Column="6" Text="고객명" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <TextBox Grid.Column="7" Style="{StaticResource RoundedTextBox}" />

                <TextBlock Grid.Column="9" Text="시작일자" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <DatePicker Grid.Column="10" Style="{StaticResource RoundedDatePicker}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="12" Text="종료일자" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <DatePicker Grid.Column="13" Style="{StaticResource RoundedDatePicker}" Margin="0,0,8,0" VerticalAlignment="Center"/>

                <TextBlock Grid.Column="15" Text="상태" Margin="0,0,8,0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <ComboBox Grid.Column="16" Style="{StaticResource RoundedComboBox}" Margin="0,0,8,0">
                    <ComboBoxItem IsSelected="True">전체</ComboBoxItem>
                    <ComboBoxItem>진행중</ComboBoxItem>
                    <ComboBoxItem>완료</ComboBoxItem>
                </ComboBox>

                <StackPanel Grid.Column="18" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="조회"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            Background="{DynamicResource PrimaryActionBrush}"
                            Foreground="{DynamicResource PrimaryActionTextBrush}"
                            BorderBrush="{DynamicResource PrimaryActionBrush}"/>
                    <Button Content="초기화"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            Background="{DynamicResource SecondaryActionBrush}"
                            Foreground="{DynamicResource SecondaryActionTextBrush}"
                            BorderBrush="{DynamicResource SecondaryActionBrush}"/>
                    
                    <Button Content="등록"
                            Margin="8,0,0,0"
                            Padding="14,8"
                            Background="{DynamicResource PrimarySaveBrush}"
                            Foreground="{DynamicResource PrimaryActionTextBrush}"
                            BorderBrush="{DynamicResource PrimarySaveBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition x:Name="PdfPanelColumn" Width="0"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="12"
                    Background="{DynamicResource ViewHeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <DataGrid x:Name="WorkOrderGrid"
                          AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          SelectionChanged="WorkOrderGrid_SelectionChanged"
                          Background="{DynamicResource ViewHeaderBackgroundBrush}"
                          Foreground="{DynamicResource ViewBodyTextBrush}"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          RowHeight="40"
                          MinRowHeight="40"
                          ColumnHeaderHeight="42"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource ViewPanelBorderBrush}"
                          VerticalGridLinesBrush="{DynamicResource ViewPanelBorderBrush}"
                          RowBackground="{DynamicResource ViewPanelBackgroundBrush}"
                          AlternatingRowBackground="{DynamicResource ViewCardBackgroundBrush}">
                    <DataGrid.Resources>
                        <Style x:Key="CenteredDataGridTextStyle" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ViewRightPaneBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="42"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryActionBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryActionTextBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="작업지시번호" Binding="{Binding WorkOrderNo}" Width="*" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="설비명" Binding="{Binding MachineName}" Width="*" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="고객명" Binding="{Binding CustomerName}" Width="*" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="상태" Binding="{Binding Status}" Width="100" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="일자" Binding="{Binding WorkDate}" Width="140" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <Border Grid.Column="1"
                    x:Name="PdfPanel"
                    Padding="12"
                    Background="{DynamicResource ViewRightPaneBackgroundBrush}"
                    BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="PDF 미리보기"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ViewBodyTextBrush}" />
                        <Button Grid.Column="1"
                                Content="닫기"
                                Width="70"
                                Height="32"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource SecondaryActionBrush}"
                                Foreground="{DynamicResource SecondaryActionTextBrush}"
                                BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                                Click="ClosePdfPanel_Click"/>
                    </Grid>

                    <Grid Grid.Row="1">
                        <Border Background="{DynamicResource ViewCanvasBackgroundBrush}" CornerRadius="8"/>
                        <wv2:WebView2 x:Name="PdfViewer" Margin="1"/>
                        <TextBlock x:Name="PdfFallbackText"
                                   Text="PDF를 불러올 수 없습니다."
                                   Foreground="{DynamicResource ViewBodyTextBrush}"
                                   FontSize="14"
                                   Visibility="Collapsed"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
