<!-- 대시보드 화면 -->
<UserControl x:Class="PlantManagement.Views.Views.DashBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:wpf="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:local="clr-namespace:PlantManagement.Views.Views"
             mc:Ignorable="d"
             d:DesignHeight="300"
             d:DesignWidth="300"
             Background="Transparent">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 상단 헤더 -->
        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="{DynamicResource ViewHeaderBackgroundColor}"
                CornerRadius="12"
                BorderBrush="{DynamicResource ViewHeaderBorderColor}"
                BorderThickness="1">
            
            <StackPanel>
                <TextBlock Text="DashBoard"
                           Foreground="{DynamicResource ViewTitleForegroundColor}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="대시보드 현황판"
                           Foreground="{DynamicResource ViewSubtitleForegroundColor}"
                           FontSize="12"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 1번째 Row -->
        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                CornerRadius="12"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <ListView Grid.Row="1"
                          ItemsSource="{Binding NoticeItems}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Background="{Binding ListViewCardBackgroundColor}"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ListViewCardForegroundColor}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <Border Grid.Column="0"
                                            Width="30"
                                            Height="30"
                                            Background="{DynamicResource PrimaryActionBackgroundColor}"
                                            CornerRadius="15"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding No}"
                                                   Foreground="{DynamicResource PrimaryActionForegroundColor}"
                                                   FontSize="12"
                                                   FontWeight="12"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    
                                    <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ViewBodyForegroundColor3}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ViewBodyForegroundColor2}"
                                                   Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                    
                                    <StackPanel Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CreateUser}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ViewBodyForegroundColor3}"
                                                   HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding CreateDt}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource ViewBodyForegroundColor2}"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    
        <!-- 2번째 Row -->
        <Border Grid.Row="2"
                Padding="10"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                CornerRadius="8"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <wpf:CartesianChart Series="{Binding StackSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                Background="Transparent"/>
        </Border>
        
        <!-- 3번째 Row -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- 목표치 -->
            <Border Grid.Column="0"
                    Margin="0 10 0 0"
                    Padding="10"
                    Background="{DynamicResource ViewPanelBackgroundColor}"
                    BorderBrush="{DynamicResource ViewPanelBorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                <wpf:CartesianChart Series="{Binding TargetSeries}" Background="Transparent"/>
            </Border>
            
            <!-- 설비별 생산개수 -->
            <Border Grid.Column="1"
                    Margin="10 10 0 0"
                    Padding="10"
                    Background="{DynamicResource ViewPanelBackgroundColor}"
                    BorderBrush="{DynamicResource ViewPanelBorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                <wpf:PieChart Series="{Binding EquipProductSeries}" Background="Transparent"/>
            </Border>
            
            <Border Grid.Column="2"
                    Margin="10 10 0 0"
                    Padding="10"
                    Background="{DynamicResource ViewPanelBackgroundColor}"
                    BorderBrush="{DynamicResource ViewPanelBorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <wpf:PieChart Series="{Binding DefectRateSeries}" LegendPosition="Hidden" Background="Transparent"/>
                    
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="85"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ViewBodyTextColor}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="%"
                                   FontSize="18"
                                   Foreground="{DynamicResource ViewTertiaryTextColor}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
