<UserControl x:Class="PlantManagement.Views.Views.WorkStatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:PlantManagement.Comm.Converters"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:DoubleToGridLengthConverter x:Key="DoubleToGridLengthConverter"/>
        <converters:SafeUriConverter x:Key="SafeUriConverter"/>
        
       <ControlTemplate x:Key="RoundedComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>
                    <ContentPresenter Grid.Column="0"
                                      Margin="12,0,8,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      RecognizesAccessKey="True" />
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0"
                          Stroke="{DynamicResource ComboBoxArrowBrush}"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxHoverBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxHoverBorderBrush}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxOpenBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxOpenBorderBrush}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxOpenArrowBrush}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxDisabledBackgroundBrush}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxDisabledBorderBrush}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxDisabledArrowBrush}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>
        
        <Style x:Key="RoundedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemForegroundColor}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxHoverBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemSelectedBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="160"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource RoundedComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Template="{StaticResource RoundedComboBoxToggleButton}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource ComboBoxBackgroundColor}"
                                        BorderBrush="{DynamicResource ComboBoxPopupBorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer Margin="0,2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource ComboBoxFocusBorderColor}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="40" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="140"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>    
        
        
        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1"
                CornerRadius="12">
            
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- 작업지시 번호 -->
                    <TextBlock Text="작업지시 번호"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0"
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- 설비명 -->
                    <TextBlock Text="설비명"
                               VerticalAlignment="Center"
                               Margin="20,0,8,0"
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding MachineKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- 고객명 -->
                    <TextBlock Text="고객명"
                               VerticalAlignment="Center"
                               Margin="20,0,8,0"
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <TextBox Style="{StaticResource RoundedTextBox}"
                             Text="{Binding CustomerKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- 시작날짜 DatePicker -->
                    <TextBlock Text="시작일자"
                               VerticalAlignment="Center"
                               Margin="20,0,8,0"
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <DatePicker Style="{StaticResource RoundedDatePicker}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                SelectedDate="{Binding StartDateFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- 종료일자 DatePicker -->
                    <TextBlock Text="종료일자"
                               VerticalAlignment="Center"
                               Margin="20,0,8,0"
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <DatePicker Style="{StaticResource RoundedDatePicker}"
                                Margin="0,0,8,0"
                                VerticalAlignment="Center"
                                SelectedDate="{Binding EndDateFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    
                    <!-- 상태 ComboBox -->
                    <TextBlock Text="상태" 
                               VerticalAlignment="Center"
                               Margin="20,0,8,0" 
                               Foreground="{DynamicResource ViewBodyTextColor}"/>
                    <ComboBox Style="{StaticResource RoundedComboBox}"
                              Margin="0,0,8,0"
                              SelectedValuePath="Content"
                              SelectedValue="{Binding SelectedStatusFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem IsSelected="True">전체</ComboBoxItem>
                        <ComboBoxItem>진행중</ComboBoxItem>
                        <ComboBoxItem>완료</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="조회"
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Background="{DynamicResource PrimaryActionBackgroundColor}"
                            Foreground="{DynamicResource PrimaryActionForegroundColor}"
                            BorderBrush="{DynamicResource PrimaryActionBackgroundColor}"
                            Command="{Binding SearchCommand}"/>
                    
                    <Button Content="초기화"
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Background="{DynamicResource SecondaryActionColor}"
                            Foreground="{DynamicResource PrimaryActionForegroundColor}"
                            BorderBrush="{DynamicResource SecondaryActionColor}"
                            Command="{Binding ResetCommand}"/>
                            
                    <Button Content="등록"
                            Margin="0,0,8,0"
                            Padding="14,8"
                            Background="{DynamicResource PrimarySaveBackgroundColor}"
                            Foreground="{DynamicResource PrimaryActionForegroundColor}"
                            BorderBrush="{DynamicResource PrimarySaveBackgroundColor}"
                            Command="{Binding AddCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
        
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="{Binding PdfPanelWidth, Converter={StaticResource DoubleToGridLengthConverter}, Mode=TwoWay}"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0"
                    Padding="12"
                    Background="{DynamicResource ViewHeaderBackgroundColor}"
                    BorderBrush="{DynamicResource ViewPanelBorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                <DataGrid AutoGenerateColumns="False"
                          HeadersVisibility="Column"
                          CanUserAddRows="False"
                          IsReadOnly="True"
                          ItemsSource="{Binding FilteredWorkStatus}"
                          SelectedItem="{Binding SelectedWorkStatus, Mode=TwoWay}"
                          Background="{DynamicResource ViewHeaderBackgroundColor}"
                          Foreground="{DynamicResource ViewBodyTextColor}"
                          BorderThickness="0"
                          RowHeaderWidth="0"
                          RowHeight="40"
                          MinRowHeight="40"
                          ColumnHeaderHeight="42"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="{DynamicResource ViewPanelBorderColor}"
                          VerticalGridLinesBrush="{DynamicResource ViewPanelBorderColor}"
                          RowBackground="{DynamicResource ViewPanelBackgroundColor}"
                          AlternatingRowBackground="{DynamicResource ListViewCardBackgroundColor}">
                    <DataGrid.Resources>
                        <Style x:Key="CenteredDataGridTextStyle" TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="VerticalAlignment" Value="Center"/>
                            <Setter Property="TextAlignment" Value="Center"/>
                        </Style>
                    </DataGrid.Resources>
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ViewPanelBackgroundColor}"/>
                            <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundColor}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBackgroundColor}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="42"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource PrimaryActionBackgroundColor}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundColor}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="작업지시번호"
                                            Binding="{Binding WorkOrderNo}"
                                            Width="150"
                                            ElementStyle="{StaticResource CenteredDataGridTextStyle}"/>          
                        
                        <DataGridTextColumn Header="설비명" 
                                            Binding="{Binding MachineName}" 
                                            Width="150"
                                            ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        
                        <DataGridTextColumn Header="고객명" 
                                            Binding="{Binding CustomerName}" 
                                            Width="150" 
                                            ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        
                        <DataGridTextColumn Header="상태" 
                                            Binding="{Binding Status}"
                                            Width="100" 
                                            ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        
                        <DataGridTextColumn Header="일자" 
                                            Binding="{Binding WorkDate}" 
                                            Width="140" 
                                            ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
            
            <!-- PDF 미리보기 -->
            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Stretch"
                          ResizeBehavior="PreviousAndNext"
                          ResizeDirection="Columns"
                          ShowsPreview="True"
                          Visibility="{Binding IsPdfPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                          Background="{DynamicResource ViewPanelBorderColor}"/>
                
              <Border Grid.Column="2"
                    Visibility="{Binding IsPdfPanelOpen, Converter={StaticResource BoolToVisibilityConverter}}"
                    MinWidth="360"
                    Padding="12"
                    Background="{DynamicResource ViewPanelBackgroundColor}"
                    BorderBrush="{DynamicResource ViewPanelBorderColor}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="PDF 미리보기"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource ViewBodyTextColor}"/>
                        <Button Grid.Column="1"
                                Content="닫기"
                                Width="70"
                                Height="32"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource SecondaryActionColor}"
                                Foreground="{DynamicResource PrimaryActionForegroundColor}"
                                BorderBrush="{DynamicResource SecondaryActionColor}"
                                Command="{Binding ClosePdfPanelCommand}"/>
                    </Grid>
                    
                    <Grid Grid.Row="1">
                        <Border Background="{DynamicResource ViewPanelBackgroundColor}" CornerRadius="8"/>
                        <wv2:WebView2 Margin="1"
                                      Source="{Binding SelectedPdfUri, Converter={StaticResource SafeUriConverter}, FallbackValue=about:blank, TargetNullValue=about:blank}"/>
                        <TextBlock
                            Text="{Binding PdfFallbackMessage}"
                            Foreground="{DynamicResource ViewBodyTextColor}"
                            FontSize="14"
                            Visibility="{Binding IsPdfFallbackVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"/>
                    </Grid>
                    
                </Grid>
            </Border>
            
        </Grid>
        
    </Grid>
    
</UserControl>
