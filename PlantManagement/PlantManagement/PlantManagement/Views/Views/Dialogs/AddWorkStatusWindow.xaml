<Window x:Class="PlantManagement.Views.Views.Dialogs.AddWorkStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="작업 등록"
        Width="520"
        Height="480"
        MinWidth="520"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    <Window.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10, 4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>            
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewSubtitleForegroundColor}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Padding="16,12"
                CornerRadius="12"
                Background="{DynamicResource ViewHeaderBackgroundColor}"
                BorderBrush="{DynamicResource ViewHeaderBorderColor}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="작업 등록"
                           Foreground="{DynamicResource ViewTitleForegroundColor}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="진행할 작업을 등록해주세요"
                           Margin="0,4,0,0"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2"
                Padding="16"
                CornerRadius="12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <!-- 작업지시 번호 -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="작업지시번호 *" Style="{StaticResource InputLabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="1" Style="{StaticResource RoundedTextBox}" IsReadOnly="True" Background="DarkGray" Text="{Binding WorkOrderNo, UpdateSourceTrigger=PropertyChanged}"/>
                
                <!-- 장비명 -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="설비명 *" Style="{StaticResource InputLabelStyle}"/>
                <ComboBox Grid.Row="2"
                          Grid.Column="1"
                          Style="{StaticResource RoundedComboBox}"
                          ItemsSource="{Binding FacilityNames}"
                          SelectedItem="{Binding MachineName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="False"
                          IsTextSearchEnabled="True"/>
                
                <!-- 고객명 -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="고객명" Style="{StaticResource InputLabelStyle}"/>
                <ComboBox Grid.Row="4"
                          Grid.Column="1"
                          Style="{StaticResource RoundedComboBox}"
                          ItemsSource="{Binding CustomerNames}"
                          SelectedItem="{Binding CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          IsEditable="False"
                          IsTextSearchEnabled="True"/>
                
                <!-- 작업일자 -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="작업 일자" Style="{StaticResource InputLabelStyle}"/>
                <DatePicker Grid.Row="6" Grid.Column="1" Style="{StaticResource RoundedDatePicker}" Text="{Binding WorkDate, UpdateSourceTrigger=PropertyChanged}"/>
                
                <TextBlock Grid.Row="8" Grid.Column="0" Grid.ColumnSpan="2"
                           Style="{StaticResource HintStyle}"
                           Text="{Binding ValidationMessage}"/>
            </Grid>
        </Border>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="저장"
                    Width="110"
                    Height="38"
                    Margin="0,0,8,0"
                    Background="{DynamicResource PrimarySaveBackgroundColor}"
                    Foreground="{DynamicResource PrimaryActionForegroundColor}"
                    BorderBrush="{DynamicResource PrimarySaveBackgroundColor}"
                    Command="{Binding SaveCommand}"/>
            
            <Button Content="취소"
                    Width="110"
                    Height="38"
                    Margin="0,0,8,0"
                    Background="{DynamicResource SecondaryActionColor}"
                    Foreground="{DynamicResource PrimaryActionForegroundColor}"
                    BorderBrush="{DynamicResource SecondaryActionColor}"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
        
        
    </Grid>
</Window>
