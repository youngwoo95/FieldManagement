<Window x:Class="PlantManagement.Views.Views.Dialogs.AddWorkStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="작업 등록"
        Width="520"
        Height="500"
        MinWidth="520"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    <Window.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10, 4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>            
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewSubtitleForegroundColor}"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Padding="16,12"
                CornerRadius="12"
                Background="{DynamicResource ViewHeaderBackgroundColor}"
                BorderBrush="{DynamicResource ViewHeaderBorderColor}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="작업 등록"
                           Foreground="{DynamicResource ViewTitleForegroundColor}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="진행할 작업을 등록해주세요"
                           Margin="0,4,0,0"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2"
                Padding="16"
                CornerRadius="12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    
                </Grid.ColumnDefinitions>
            </Grid>
            
        </Border>
        
    </Grid>
</Window>
