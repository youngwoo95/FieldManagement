<Window x:Class="PlantManagement.Views.Views.Dialogs.AddWorkStatusWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:converters="clr-namespace:PlantManagement.Comm.Converters"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="작업 등록"
        Width="980"
        Height="620"
        MinWidth="920"
        MinHeight="560"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <converters:SafeUriConverter x:Key="SafeUriConverter"/>

        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="RoundedDatePicker" TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="430"/>
            <ColumnDefinition Width="16"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Padding="16"
                CornerRadius="12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <TextBlock Text="작업 등록"
                               Foreground="{DynamicResource ViewTitleForegroundColor}"
                               FontSize="20"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="수주를 선택하면 고객명과 PDF가 자동 반영됩니다."
                               Margin="0,4,0,0"
                               Foreground="{DynamicResource ViewSubtitleForegroundColor}"
                               FontSize="12"/>
                </StackPanel>

                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="작업지시번호*" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Style="{StaticResource RoundedTextBox}"
                             Text="{Binding WorkOrderNo, UpdateSourceTrigger=PropertyChanged}"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="수주 정보*" Style="{StaticResource InputLabelStyle}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              Style="{StaticResource RoundedComboBox}"
                              ItemsSource="{Binding OrderInfos}"
                              SelectedItem="{Binding SelectedOrderInfo, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DisplayMemberPath="DisplayText"
                              IsEditable="False"
                              IsTextSearchEnabled="True"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="고객명" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Style="{StaticResource RoundedTextBox}"
                             Text="{Binding CustomerName}"
                             IsReadOnly="True"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="설비명*" Style="{StaticResource InputLabelStyle}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1"
                              x:Name="FacilityComboBox"
                              Style="{StaticResource RoundedComboBox}"
                              ItemsSource="{Binding FacilityNames}"
                              SelectedItem="{Binding MachineName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              DropDownOpened="FacilityComboBox_OnDropDownOpened"
                              IsEditable="False"
                              IsTextSearchEnabled="True"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="작업 일자" Style="{StaticResource InputLabelStyle}"/>
                    <DatePicker Grid.Row="8" Grid.Column="1"
                                Style="{StaticResource RoundedDatePicker}"
                                Text="{Binding WorkDate, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                               Foreground="{DynamicResource SecondaryActionColor}"
                               FontSize="12"
                               Text="{Binding ValidationMessage}"/>
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="저장"
                            Width="110"
                            Height="38"
                            Margin="0,0,8,0"
                            Background="{DynamicResource PrimarySaveBackgroundColor}"
                            Foreground="{DynamicResource PrimaryActionForegroundColor}"
                            BorderBrush="{DynamicResource PrimarySaveBackgroundColor}"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="취소"
                            Width="110"
                            Height="38"
                            Background="{DynamicResource SecondaryActionColor}"
                            Foreground="{DynamicResource PrimaryActionForegroundColor}"
                            BorderBrush="{DynamicResource SecondaryActionColor}"
                            Command="{Binding CancelCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="2"
                Padding="12"
                CornerRadius="12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="수주 PDF 미리보기"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ViewBodyTextColor}"/>

                <TextBlock Grid.Row="1"
                           Margin="0,6,0,10"
                           FontSize="12"
                           Foreground="{DynamicResource ViewBodyTextColor}"
                           Text="{Binding SelectedOrderSummary}"/>

                <Grid Grid.Row="2">
                    <Border Background="{DynamicResource ViewPanelBackgroundColor}" CornerRadius="8"/>
                    <wv2:WebView2 Margin="1"
                                  Source="{Binding SelectedPdfUri, Converter={StaticResource SafeUriConverter}, FallbackValue=about:blank, TargetNullValue=about:blank}"/>
                    <TextBlock Text="{Binding PdfFallbackMessage}"
                               Foreground="{DynamicResource ViewBodyTextColor}"
                               FontSize="14"
                               Visibility="{Binding IsPdfFallbackVisible, Converter={StaticResource BoolToVisibilityConverter}}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextAlignment="Center"/>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Window>
