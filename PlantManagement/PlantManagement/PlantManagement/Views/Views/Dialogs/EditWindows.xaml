<Window x:Class="PlantManagement.Views.Views.Dialogs.EditWindows"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="층 장비 편집"
        Width="720"
        Height="520"
        MinWidth="660"
        MinHeight="480"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    <Window.Resources>
        <Style x:Key="EditorSectionBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource ViewPanelBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
        </Style>

        <Style x:Key="EditorTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
        </Style>

        <Style x:Key="EditorTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}" />
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <ControlTemplate x:Key="RoundedComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="32" />
                    </Grid.ColumnDefinitions>

                    <ContentPresenter Grid.Column="0"
                                      Margin="12,0,8,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Left"
                                      RecognizesAccessKey="True" />

                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0"
                          Stroke="{DynamicResource ComboBoxArrowColor}"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" />
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxHoverBackgroundColor}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxHoverBorderColor}" />
                </Trigger>
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxOpenBackgroundColor}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxOpenBorderColor}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxOpenArrowColor}" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxDisabledBackgroundColor}" />
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxDisabledBorderColor}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxDisabledArrowColor}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="RoundedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemForegroundColor}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemHoverBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemSelectedBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Width" Value="160" />
            <Setter Property="Height" Value="38" />
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource RoundedComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Template="{StaticResource RoundedComboBoxToggleButton}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left" />
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource ComboBoxBackgroundColor}"
                                        BorderBrush="{DynamicResource ComboBoxPopupBorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer Margin="0,2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource ComboBoxFocusBorderColor}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="40" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource ViewHeaderBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}" />
            <Setter Property="Padding" Value="6" />
        </Style>

        <Style x:Key="EditorListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Background" Value="{DynamicResource ViewPanelBackgroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ComboBoxItemHoverBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource PrimaryActionBackgroundColor}" />
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource SidebarIndicatorColor}" />
                                <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="{DynamicResource PrimaryActionBackgroundColor}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryActionBackgroundColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="38" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Background" Value="{DynamicResource SecondaryActionColor}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryActionForegroundColor}" />
            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderColor}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource EditorSectionBorderStyle}" Padding="14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="62" />
                        <ColumnDefinition Width="170" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="75" />
                        <ColumnDefinition Width="18" />
                        <ColumnDefinition Width="62" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="층명"
                               VerticalAlignment="Center"
                               Style="{StaticResource EditorTitleStyle}" />
                    <TextBox Grid.Column="1"
                             x:Name="FloorNameTextBox"
                             Style="{StaticResource EditorTextBoxStyle}" />
                    <Button Grid.Column="3"
                            Content="조회"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Click="SearchFloorButton_Click" />
                    <Button Grid.Column="5"
                            x:Name="CreateFloorButton"
                            Content="생성"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="CreateFloorButton_Click" />
                    <TextBlock Grid.Column="7"
                               Text="목록"
                               VerticalAlignment="Center"
                               Style="{StaticResource EditorTitleStyle}" />
                    <ComboBox Grid.Column="8"
                              x:Name="FloorComboBox"
                              Style="{StaticResource RoundedComboBox}"
                              Width="Auto"
                              SelectionChanged="FloorComboBox_SelectionChanged" />
                </Grid>
                <TextBlock Grid.Row="2"
                           x:Name="FloorMessageText"
                           Foreground="{DynamicResource ViewSubtitleForegroundColor}" />
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource EditorSectionBorderStyle}" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,10,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="전체 장비 목록"
                               Style="{StaticResource EditorTitleStyle}" />
                    <ListBox Grid.Row="2"
                             x:Name="AllEquipmentListBox"
                             Style="{StaticResource EditorListBoxStyle}"
                             ItemContainerStyle="{StaticResource EditorListBoxItemStyle}"
                             DisplayMemberPath="Name"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="EquipmentListBox_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="EquipmentListBox_PreviewMouseMove"
                             DragOver="EquipmentListBox_DragOver"
                             Drop="EquipmentListBox_Drop" />
                </Grid>

                <TextBlock Grid.Column="1"
                           Text="⇄"
                           Foreground="{DynamicResource ViewSubtitleForegroundColor}"
                           FontSize="20"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Center" />

                <Grid Grid.Column="2" Margin="10,0,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="해당 층 장비"
                               Style="{StaticResource EditorTitleStyle}" />
                    <ListBox Grid.Row="2"
                             x:Name="FloorEquipmentListBox"
                             Style="{StaticResource EditorListBoxStyle}"
                             ItemContainerStyle="{StaticResource EditorListBoxItemStyle}"
                             DisplayMemberPath="Name"
                             AllowDrop="True"
                             PreviewMouseLeftButtonDown="EquipmentListBox_PreviewMouseLeftButtonDown"
                             PreviewMouseMove="EquipmentListBox_PreviewMouseMove"
                             DragOver="EquipmentListBox_DragOver"
                             Drop="EquipmentListBox_Drop" />
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="저장"
                    Width="100"
                    Margin="0,0,8,0"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveButton_Click" />
            <Button Content="닫기"
                    Width="100"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Click="ButtonBase_OnClick" />
        </StackPanel>
    </Grid>
</Window>
