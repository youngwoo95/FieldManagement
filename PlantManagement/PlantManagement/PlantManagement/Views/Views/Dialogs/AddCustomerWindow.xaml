<Window x:Class="PlantManagement.Views.Views.Dialogs.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PlantManagement.Views.Views.Dialogs"
        mc:Ignorable="d"
        Title="고객사 등록" 
        Height="700" 
        Width="820"
        MinHeight="620"
        MaxHeight="900"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    
    <Window.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewSubtitleForegroundColor}" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10, 4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        
        <ControlTemplate x:Key="RoundedComboBoxToggleButton" TargetType="ToggleButton">
            <Border x:Name="ToggleBorder"
                    CornerRadius="8"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="32"/>
                    </Grid.ColumnDefinitions>
                    
                    <ContentPresenter Grid.Column="0"
                                      Margin="12,0,8,0"
                                      VerticalAlignment="Center"
                                      HorizontalAlignment="Center"
                                      RecognizesAccessKey="True"/>
                    <Path x:Name="Arrow"
                          Grid.Column="1"
                          VerticalAlignment="Center"
                          HorizontalAlignment="Center"
                          Data="M 0 0 L 4 4 L 8 0"
                          Stroke="{DynamicResource ComboBoxArrowColor}"
                          StrokeThickness="2"
                          SnapsToDevicePixels="True" /> <!-- 값을 True로 두면 1px 선/테두리가 반픽셀에 걸려서 흐릿해지는 걸 줄여줍니다. -->
                </Grid>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxHoverBorderColor}"/>
                </Trigger>
                
                <Trigger Property="IsChecked" Value="True">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxOpenBackgroundColor}"/>
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxOpenBorderColor}"/>
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxOpenArrowColor}"/>
                </Trigger>
                
                <Trigger Property="IsEnabled" Value="False">
                    <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource ComboBoxDisabledBackgroundColor}"/>
                    <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{DynamicResource ComboBoxDisabledBorderColor}" />
                    <Setter TargetName="Arrow" Property="Stroke" Value="{DynamicResource ComboBoxDisabledArrowColor}" />
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

       <Style x:Key="RoundedComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemForegroundColor}" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="ItemBorder"
                                Margin="4,2"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="6"
                                Background="Transparent">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemHoverBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ComboBoxItemSelectedBackgroundColor}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundedComboBox" TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundColor}"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundColor}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="TextBlock.TextAlignment" Value="Center" />
            <Setter Property="MaxDropDownHeight" Value="280" />
            <Setter Property="ScrollViewer.CanContentScroll" Value="True" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource RoundedComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                          Template="{StaticResource RoundedComboBoxToggleButton}">
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Center"/>
                            </ToggleButton>

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        Margin="0,6,0,0"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource ComboBoxBackgroundColor}"
                                        BorderBrush="{DynamicResource ComboBoxPopupBorderColor}"
                                        BorderThickness="1"
                                        CornerRadius="8">
                                    <ScrollViewer Margin="0,2"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ToggleButton" Property="BorderBrush" Value="{DynamicResource ComboBoxFocusBorderColor}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="40" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource ComboBoxItemDisabledForegroundColor}" />
                                <Setter TargetName="ToggleButton" Property="Opacity" Value="0.8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="14"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Padding="16,12"
                CornerRadius="12"
                Background="{DynamicResource ViewHeaderBackgroundColor}"
                BorderBrush="{DynamicResource ViewHeaderBorderColor}"
                BorderThickness="1">
            <StackPanel>
                <TextBlock Text="고객사 등록"
                           Foreground="{DynamicResource ViewTitleForegroundColor}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="고객사 기본 정보와 담당자 정보를 입력해주세요."
                           Margin="0,4,0,0"
                           Style="{StaticResource HintStyle}"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2"
                Padding="16"
                CornerRadius="12"
                Background="{DynamicResource ViewPanelBackgroundColor}"
                BorderBrush="{DynamicResource ViewPanelBorderColor}"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="12"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="고객사명 *" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="CustomerNameTextBox" Style="{StaticResource RoundedTextBox}" Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="고객구분" Style="{StaticResource InputLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="4" x:Name="CustomerTypeComboBox" Style="{StaticResource RoundedComboBox}" SelectedItem="{Binding CustomerGubun, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <ComboBoxItem Content="일반"/>
                        <ComboBoxItem Content="협력사"/>
                        <ComboBoxItem Content="주요고객"/>
                    </ComboBox>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="담당자명" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="ManagerNameTextBox" Style="{StaticResource RoundedTextBox}" Text="{Binding ManagerName, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="부서" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="4" x:Name="DepartmentTextBox" Style="{StaticResource RoundedTextBox}" />

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="연락처" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" x:Name="PhoneTextBox" Style="{StaticResource RoundedTextBox}" Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}" />
                    <TextBlock Grid.Row="4" Grid.Column="3" Text="이메일" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="4" x:Name="EmailTextBox" Style="{StaticResource RoundedTextBox}" />


                    <TextBlock Grid.Row="6" Grid.Column="0" Text="주소" Style="{StaticResource InputLabelStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="4" x:Name="AddressTextBox" Style="{StaticResource RoundedTextBox}" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="비고" Style="{StaticResource InputLabelStyle}" VerticalAlignment="Top"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Grid.ColumnSpan="4"
                             x:Name="MemoTextBox"
                             Height="120"
                             VerticalContentAlignment="Top"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Padding="10,8"
                             FontSize="14"
                             Foreground="{DynamicResource ComboBoxForegroundColor}"
                             Background="{DynamicResource ComboBoxBackgroundColor}"
                             BorderBrush="{DynamicResource ComboBoxBorderColor}"
                             BorderThickness="1"/>
                    
                    <TextBlock Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="4"
                               x:Name="ValidationText"
                               Style="{StaticResource HintStyle}"
                               Text="{Binding ValidationMessage}"/>
                </Grid>
            </ScrollViewer>
        </Border>
        
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <!-- 여기에 Save Command 들어가야함. -->
            <Button Content="저장"
                    Width="110"
                    Height="38"
                    Cursor="Hand"
                    Margin="0,0,8,0"
                    Background="{DynamicResource PrimarySaveBackgroundColor}"
                    Foreground="{DynamicResource PrimaryActionForegroundColor}"
                    BorderBrush="{DynamicResource PrimarySaveBackgroundColor}"
                    Command="{Binding SaveCommand}"/>
            
            <Button Content="편집"
                    Width="110"
                    Height="38"
                    Cursor="Hand"
                    Margin="0,0,8,0"
                    Background="{DynamicResource PrimarySaveBackgroundColor}"
                    Foreground="{DynamicResource PrimaryActionForegroundColor}"
                    BorderBrush="{DynamicResource PrimarySaveBackgroundColor}"
                    Command="{Binding EditCommand}"/>
            
            <!-- 여기에 Cancel Command 들어가야함. -->
            <Button Content="취소"
                    Width="110"
                    Height="38"
                    Cursor="Hand"
                    Background="{DynamicResource SecondaryActionColor}"
                    Foreground="{DynamicResource PrimaryActionForegroundColor}"
                    BorderBrush="{DynamicResource SecondaryActionColor}"
                    Command="{Binding CancelCommand}"/>
        </StackPanel>
    </Grid>
</Window>
