<Window x:Class="PlantManagement.Views.Views.Dialogs.AddCustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:PlantManagement.Views.Views.Dialogs"
        mc:Ignorable="d"
        Title="고객사 등록" 
        Height="620" 
        Width="820"
        MinHeight="620"
        MaxHeight="820"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource WindowBackgroundColor}">
    
    <Window.Resources>
        <Style x:Key="InputLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextColor}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>
    
    <Grid>
        
    </Grid>
</Window>
