<Window x:Class="PlantManagement.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:PlantManagement.Views.Views"
        xmlns:dashboard="clr-namespace:PlantManagement.Views.ViewModels.DashBoardModel"
        xmlns:customer="clr-namespace:PlantManagement.Views.ViewModels.CustomerModel"
        xmlns:facility="clr-namespace:PlantManagement.Views.ViewModels.FacilityModel"
        mc:Ignorable="d"
        Title="생산관리 시스템"
        Height="720" 
        Width="1280"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundColor}">
    
    <!-- 해당 윈도우의 전역 스타일 지정 -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type dashboard:DashBoardViewModel}">
            <views:DashBoardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type customer:CustomerViewModel}">
            <views:CustomerView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type facility:FacilityViewModel}">
            <views:FacilityView/>
        </DataTemplate>
        
        
        <!-- 사이드바 라디오 버튼 스타일 -->
        <Style x:Key="SidebarRadioStyle" TargetType="RadioButton">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="8, 6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundColor}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/> <!-- 키보드 포커스 시각효과 끔. (Tab 이동같은 것) -->
            <Setter Property="Template"> <!-- 컨트롤의 ControlTemplate(겉모양/구조)를 바꾸는 설정이다. -->
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Grid>
                            <Border x:Name="Indicator"
                                    Width="4"
                                    Margin="0,8,0,8"
                                    HorizontalAlignment="Left"
                                    Background="Transparent"
                                    CornerRadius="2"/>
                            
                            <Border x:Name="ButtonBody"
                                    Margin="8,0,0,0"
                                    Background="Transparent"
                                    CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                        
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarHoverColor}"/>
                            </Trigger>
                            
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource SidebarIndicatorColor}"/>
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarSelectedColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- 사이드바 버튼 스타일 -->
        <Style x:Key="SidebarButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundColor}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBody" Background="{TemplateBinding Background}" CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarHoverColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarPressedColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        
    </Window.Resources>
    
    
    
    <!-- 화면 영역 -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="88"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- 왼쪽 사이드바 -->
        <Border Grid.Column="0" Background="{DynamicResource SidebarBackgroundColor}">
            <DockPanel LastChildFill="True">
                <!-- 하단 -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0, 0,0,10">
                     
                    <Button Style="{StaticResource SidebarButtonStyle}" Command="{Binding ToggleThemeCommand}">                         
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="◐" FontSize="22" Foreground="{DynamicResource SidebarForegroundColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="테마" FontSize="11" Foreground="{DynamicResource SidebarForegroundColor}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
                
                <!-- 상단 -->
                <StackPanel Margin="0,10,0,0">
                    <!-- 대시보드 버튼 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}" IsChecked="{Binding IsDashBoardSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="" FontFamily="Segoe MDL2 Assets" FontSize="24" Foreground="{DynamicResource SidebarForegroundColor}" HorizontalAlignment="Center"/>
                            <TextBlock Text="대시보드" FontSize="11" Foreground="{DynamicResource SidebarForegroundColor}" Margin="0,4,0,0" HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <!-- 설비 현황판 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="설비현황판"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <!-- 작업관리 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="작업관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       Margin="0, 4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <!-- 수주관리 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="수주관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <!-- 설비관리 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}" IsChecked="{Binding IsFacilityManagement, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="설비관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <!-- 고객사 관리 -->
                    <RadioButton Style="{StaticResource SidebarRadioStyle}" IsChecked="{Binding IsCustomerManagement, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="고객사 관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundColor}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                        
                    </RadioButton>
                    
                </StackPanel>
            </DockPanel>
        </Border>
        
        <!-- 우측 화면 -->
        <ContentControl Grid.Column="1" Margin="14" Content="{Binding CurrentViewModel}"/>
        
    </Grid>
</Window>
