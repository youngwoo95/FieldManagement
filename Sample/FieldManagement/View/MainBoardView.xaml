<!--
대시보드
-->
 <UserControl x:Class="FieldManagement.View.MainBoardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wpf="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignWidth="1200"
             d:DesignHeight="800"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- 상단 헤더 -->
        <Border Grid.Row="0"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="{DynamicResource ViewHeaderBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{DynamicResource ViewHeaderBorderBrush}"
                BorderThickness="1">
            
            <StackPanel>
                <TextBlock Text="Main DashBoard"
                           Foreground="{DynamicResource ViewTitleTextBrush}"
                           FontSize="20"
                           FontWeight="SemiBold"/>
                <TextBlock Text="대시보드 현황판"
                           Foreground="{DynamicResource ViewSubtitleTextBrush}"
                           FontSize="12"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1"
                Margin="0,0,0,12"
                Padding="16,12"
                Background="{DynamicResource ViewPanelBackgroundBrush}"
                CornerRadius="12"
                BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                BorderThickness="1">
            
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                
                <!-- <TextBlock Text="공지사항" -->
                <!--            Foreground="White"  -->
                <!--            FontSize="12" -->
                <!--            FontWeight="SemiBold" -->
                <!--            Margin="0,4,0,0"/> -->
                
                <ListView Grid.Row="1"
                          ItemsSource="{Binding Notices}"
                          Background="Transparent"
                          BorderThickness="0"
                          ScrollViewer.VerticalScrollBarVisibility="Auto">
                    
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Margin" Value="0,0,0,6"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    
                     <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10"
                                    Background="{DynamicResource ViewCardBackgroundBrush}"
                                    CornerRadius="8"
                                    BorderBrush="{DynamicResource ViewCardBorderBrush}"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="30"
                                            Height="30"
                                            Background="{DynamicResource PrimaryActionBrush}"
                                            CornerRadius="15"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center">
                                        <TextBlock Text="{Binding No}"
                                                   Foreground="{DynamicResource PrimaryActionTextBrush}"
                                                   FontSize="12"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel Grid.Column="1" Margin="8,0,12,0">
                                        <TextBlock Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource ViewBodyTextBrush}"/>
                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ViewMutedTextBrush}"
                                                   Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center">
                                        <TextBlock Text="{Binding CreateUser}"
                                                   FontSize="11"
                                                   Foreground="{DynamicResource ViewBodyTextBrush}"
                                                   HorizontalAlignment="Right"/>
                                        <TextBlock Text="{Binding CreateDt}"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource ViewTertiaryTextBrush}"
                                                   Margin="0,2,0,0"
                                                   HorizontalAlignment="Right"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
        
        <Border Grid.Row="2"
                Margin="10"
                Padding="10"
                Background="{DynamicResource ViewCardBackgroundBrush}"
                BorderBrush="{DynamicResource ViewCardBorderBrush}"
                BorderThickness="1"
                CornerRadius="15">
            <wpf:CartesianChart Series="{Binding StackedSeries}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}" 
                                Background="Transparent"/>
        </Border>
        
        
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>    
            
            <Border Grid.Column="0"
                    Margin="10"
                    Padding="10"
                    Background="{DynamicResource ViewCardBackgroundBrush}"
                    BorderBrush="{DynamicResource ViewCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="15">
                <wpf:CartesianChart Series="{Binding Series}"
                                    Background="Transparent" />
            </Border>
            
            <Border Grid.Column="1"
                    Margin="10"
                    Padding="10"
                    Background="{DynamicResource ViewCardBackgroundBrush}"
                    BorderBrush="{DynamicResource ViewCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="15">
                <wpf:PieChart Series="{Binding PieSeries}" Background="Transparent"/>
            </Border>
            
            <Border Grid.Column="2"
                    Margin="10"
                    Padding="10"
                    Background="{DynamicResource ViewCardBackgroundBrush}"
                    BorderBrush="{DynamicResource ViewCardBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="15">
                <Grid>
                    <wpf:PieChart Series="{Binding PieSeries2}"
                                  LegendPosition="Hidden"
                                  Background="Transparent"/>

                    <StackPanel HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                        <TextBlock Text="85" 
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource ViewBodyTextBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="%" 
                                   FontSize="18"
                                   Foreground="{DynamicResource ViewTertiaryTextBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        
    </Grid>
</UserControl>