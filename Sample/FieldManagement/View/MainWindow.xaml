<Window x:Class="FieldManagement.View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:FieldManagement.View"
        xmlns:vm="clr-namespace:FieldManagement.ViewModels"
        mc:Ignorable="d"
        Title="Field Management"
        Height="720"
        Width="1280"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBackgroundBrush}">
    
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:MainBoardViewModel}">
            <views:MainBoardView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:InputViewModel}">
            <views:InputView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:OrderViewModel}">
            <views:OrderView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WorkStatusViewModel}">
            <views:WorkStatusView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:FacilityViewModel}">
            <views:FacilityView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CustomerViewModel}">
            <views:CustomerView />
        </DataTemplate>
        
        <!-- 사이드바 토글 버튼 스타일 -->
       <Style x:Key="SidebarRadioStyle" TargetType="RadioButton">
           <Setter Property="Width" Value="72"/>
           <Setter Property="Height" Value="72"/>
           <Setter Property="Margin" Value="8,6"/>
           <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundBrush}"/>
           <Setter Property="Background" Value="Transparent"/>
           <Setter Property="BorderBrush" Value="Transparent"/>
           <Setter Property="Cursor" Value="Hand"/>
           <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
           <Setter Property="Template">
               <Setter.Value>
                   <ControlTemplate TargetType="RadioButton">
                       <Grid>
                           <Border x:Name="Indicator"
                                   Width="4"
                                   Margin="0,8,0,8"
                                   HorizontalAlignment="Left"
                                   Background="Transparent"
                                   CornerRadius="2"/>

                           <Border x:Name="ButtonBody"
                                   Margin="8,0,0,0"
                                   Background="Transparent"
                                   CornerRadius="14">
                               <ContentPresenter HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"/>
                           </Border>
                       </Grid>

                       <ControlTemplate.Triggers>
                           <Trigger Property="IsMouseOver" Value="True">
                               <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                           </Trigger>

                           <Trigger Property="IsChecked" Value="True">
                               <Setter TargetName="Indicator" Property="Background" Value="{DynamicResource SidebarIndicatorBrush}"/>
                               <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarSelectedBrush}"/>
                           </Trigger>
                       </ControlTemplate.Triggers>
                   </ControlTemplate>
               </Setter.Value>
           </Setter>
       </Style>
       
        <!-- 하단 작은 버튼 -->
        <Style x:Key="SidebarBottomButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="72"/>
            <Setter Property="Margin" Value="8,6"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBody"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBody" Property="Background" Value="{DynamicResource SidebarPressedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 오른쪽 로그 리스트 스타일 -->
        <Style x:Key="LogListBoxStyle" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundBrush}"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="LogListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
            <Setter Property="Background" Value="{DynamicResource LogItemBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource SidebarForegroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LogItemBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LogItemHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource LogItemSelectedBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource LogItemSelectedBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="88"/>
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 왼쪽 사이드바 -->
        <Border Grid.Column="0"
                Background="{DynamicResource SidebarBackgroundBrush}">
            <DockPanel LastChildFill="True">

                <!-- 하단 -->
                <StackPanel DockPanel.Dock="Bottom"
                            Margin="0,0,0,10">
                    <Button Style="{StaticResource SidebarBottomButtonStyle}"
                            Command="{Binding ToggleThemeCommand}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="◐"
                                       FontSize="22"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="테마"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- 상단 메뉴 -->
                <StackPanel Margin="0,10,0,0">
                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsHomeSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="대시보드"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsInputSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="설비현황판"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsDataSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="작업관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>

                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsWorkersSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="수주관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsFacilitySelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text=""
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="설비관리"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    
                    <RadioButton Style="{StaticResource SidebarRadioStyle}"
                                 IsChecked="{Binding IsCustomerSelected, Mode=TwoWay}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="&#xE77B;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="24"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="고객사"
                                       FontSize="11"
                                       Foreground="{DynamicResource SidebarForegroundBrush}"
                                       Margin="0,4,0,0"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </DockPanel>
        </Border>

        <ContentControl Grid.Column="1"
                        Margin="14"
                        Content="{Binding CurrentViewModel}"/>
    </Grid>
</Window>
