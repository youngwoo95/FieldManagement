<!--
고객사 관리화면
-->
<UserControl x:Class="FieldManagement.View.CustomerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="Transparent">
    
    <UserControl.Resources>
        <Style x:Key="RoundedTextBox" TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10, 4"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{DynamicResource ComboBoxForegroundBrush}"/>
            <Setter Property="Background" Value="{DynamicResource ComboBoxBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource ComboBoxBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0"
                Padding="16"
                Margin="0,0,0,12"
                Background="{DynamicResource ViewPanelBackgroundBrush}"
                BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="고객사" Margin="0, 0, 8, 0" VerticalAlignment="Center" Foreground="{DynamicResource ViewBodyTextBrush}"/>
                <TextBox Grid.Column="1"
                         Style="{StaticResource RoundedTextBox}"
                         Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/>
                <Button Grid.Column="2" Content="조회"
                        Margin="8,0,0,0"
                        Padding="14,8"
                        Background="{DynamicResource PrimaryActionBrush}"
                        Foreground="{DynamicResource PrimaryActionTextBrush}"
                        BorderBrush="{DynamicResource PrimaryActionBrush}"
                        Command="{Binding SearchCommand}"/>
                <Button Grid.Column="3" Content="등록"
                        Margin="8,0,0,0"
                        Padding="14,8"
                        Background="{DynamicResource PrimarySaveBrush}"
                        Foreground="{DynamicResource PrimaryActionTextBrush}"
                        BorderBrush="{DynamicResource PrimarySaveBrush}"
                        Command="{Binding AddCommand}"/>
                <Button Grid.Column="4" Content="삭제"
                        Margin="8,0,0,0"
                        Padding="14,8"
                        Background="{DynamicResource SecondaryActionBrush}"
                        Foreground="{DynamicResource SecondaryActionTextBrush}"
                        BorderBrush="{DynamicResource SecondaryActionBrush}"
                        Command="{Binding RemoveCommand}"/>
            </Grid>
        </Border>
        
        <!-- 표 -->
        <Border Grid.Row="1"
                Margin="0,0,12,0"
                Padding="12"
                Background="{DynamicResource ViewHeaderBackgroundBrush}"
                BorderBrush="{DynamicResource ViewPanelBorderBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <DataGrid x:Name="CustomerGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      IsReadOnly="False"
                      ItemsSource="{Binding Customers}"
                      Background="{DynamicResource ViewHeaderBackgroundBrush}"
                      Foreground="{DynamicResource ViewBodyTextBrush}"
                      BorderThickness="0"
                      RowHeaderWidth="0"
                      RowHeight="40"
                      MinRowHeight="40"
                      ColumnHeaderHeight="42"
                      GridLinesVisibility="Horizontal"
                      SelectionUnit ="FullRow"
                      SelectionMode="Single"
                      HorizontalGridLinesBrush="{DynamicResource ViewPanelBorderBrush}"
                      VerticalGridLinesBrush="{DynamicResource ViewPanelBorderBrush}"
                      RowBackground="{DynamicResource ViewPanelBackgroundBrush}"
                      AlternatingRowBackground="{DynamicResource ViewCardBackgroundBrush}">
                <DataGrid.Resources>
                    <Style x:Key="CenteredDataGridTextStyle" TargetType="TextBlock">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="TextAlignment" Value="Center"/>
                    </Style>
                    <Style x:Key="LargeCheckBoxStyle" TargetType="CheckBox">
                        <Setter Property="HorizontalAlignment" Value="Center"/>
                        <Setter Property="VerticalAlignment" Value="Center"/>
                        <Setter Property="LayoutTransform">
                            <Setter.Value>
                                <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Resources>
                 <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource ViewRightPaneBackgroundBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource ViewPanelBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Height" Value="42"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="Height" Value="40"/>
                            <Setter Property="MinHeight" Value="40"/>
                            <Setter Property="Foreground" Value="{DynamicResource ViewBodyTextBrush}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="48">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Style="{StaticResource LargeCheckBoxStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="고객사명" Binding="{Binding Name}" IsReadOnly="True" Width="100" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="담당자명" Binding="{Binding Manager}" IsReadOnly="True" Width="100" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="고객구분" Binding="{Binding Gubun}" IsReadOnly="True" Width="100" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        <DataGridTextColumn Header="전화번호" Binding="{Binding Tel}" IsReadOnly="True" Width="100" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                        
                        <DataGridTextColumn Header="주소" Binding="{Binding Address}" IsReadOnly="True" Width="*" ElementStyle="{StaticResource CenteredDataGridTextStyle}" />
                    </DataGrid.Columns>
                </DataGrid>
        </Border>
        
    </Grid>
    <!-- 리스트 -->
</UserControl>
